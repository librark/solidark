{
  "name": "solidark",
  "version": "0.1.0",
  "description": "Web Component based constructive solid geometry for JavaScript.",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js",
    "./base": "./lib/base/index.js",
    "./base/component": "./lib/base/component.js",
    "./base/kernel": "./lib/base/kernel/index.js",
    "./base/kernel/*": "./lib/base/kernel/*.js",
    "./base/*": "./lib/base/*.js",
    "./component": "./lib/base/component.js",
    "./elements": "./lib/elements.js",
    "./export": "./lib/export/index.js",
    "./export/*": "./lib/export/*.js",
    "./external": "./lib/external/index.js",
    "./external/viewer": "./lib/external/viewer/index.js",
    "./external/viewer/*": "./lib/external/viewer/*.js",
    "./feature": "./lib/feature/index.js",
    "./feature/*": "./lib/feature/*/*.js",
    "./kernel": "./lib/runtime/kernel/index.js",
    "./kernel/contract": "./lib/base/kernel/contract.js",
    "./kernel/evaluate": "./lib/runtime/evaluate.js",
    "./kernel/in-memory": "./lib/base/kernel/memory.js",
    "./kernel/memory": "./lib/base/kernel/memory.js",
    "./kernel/opencascade": "./lib/runtime/kernel/opencascade.js",
    "./kernel/*": "./lib/runtime/kernel/*.js",
    "./normalize": "./lib/normalize.js",
    "./operation": "./lib/operation/index.js",
    "./operation/*": "./lib/operation/*/*.js",
    "./opencascade": "./lib/runtime/kernel/opencascade.js",
    "./primitives": "./lib/primitives/index.js",
    "./primitives/*": "./lib/primitives/*/*.js",
    "./runtime": "./lib/runtime/index.js",
    "./runtime/evaluate": "./lib/runtime/evaluate.js",
    "./runtime/kernel": "./lib/runtime/kernel/index.js",
    "./runtime/kernel/in-memory": "./lib/base/kernel/memory.js",
    "./runtime/kernel/memory": "./lib/base/kernel/memory.js",
    "./runtime/kernel/*": "./lib/runtime/kernel/*.js",
    "./runtime/runtime": "./lib/runtime/runtime.js",
    "./structures": "./lib/structures/index.js",
    "./structures/*": "./lib/structures/*/*.js",
    "./styling": "./lib/styling/index.js",
    "./styling/*": "./lib/styling/*/*.js",
    "./transform": "./lib/transform/index.js",
    "./transform/*": "./lib/transform/*/*.js",
    "./utils": "./lib/base/utils.js",
    "./viewer": "./lib/external/viewer/index.js"
  },
  "files": [
    "lib",
    "showcase",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "standard": "standard",
    "standard:fix": "standard --fix",
    "showcase": "node showcase/server.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='lib/**/*.js' --test-coverage-include='showcase/**/*.js' --test-coverage-exclude='lib/**/*.test.js' --test-coverage-exclude='showcase/**/*.test.js' --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100"
  },
  "keywords": [
    "cad",
    "csg",
    "opencascade",
    "web-components"
  ],
  "dependencies": {
    "@google/model-viewer": "4.1.0",
    "opencascade.js": "1.1.1",
    "three": "0.172.0"
  },
  "devDependencies": {
    "standard": "^17.1.0"
  },
  "license": "MIT"
}
